{
  "manifest_version": 3,
  "name": "AI Job Autofill",
  "version": "0.1.0",
  "description": "Privacy-first autofill for job applications. Deterministic first, AI-assisted, you stay in control.",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": [
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://careers.icims.com/*",
    "https://*.icims.com/*",
    "https://jobs.smartrecruiters.com/*",
    "https://careers.smartrecruiters.com/*",
    "https://*.bamboohr.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://careers.icims.com/*",
        "https://*.icims.com/*",
        "https://jobs.smartrecruiters.com/*",
        "https://careers.smartrecruiters.com/*",
        "https://*.bamboohr.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/content/index.ts"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Job Autofill — click to open the side panel"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "commands": {
    "autofill": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Autofill the current job application"
    }
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
