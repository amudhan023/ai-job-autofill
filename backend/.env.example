# Copy to .env and fill in. The app boots without these (AI features are stubbed).
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Google Gemini — used as LLM when ANTHROPIC_API_KEY is not set.
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-2.5-pro, gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Set to 1 to run deterministic fake AI (no keys needed) — used by integration tests.
USE_FAKE_AI=0

# Models (see PLAN.md §3). Defaults baked into settings; override here if needed.
RESUME_MODEL=claude-sonnet-4-6
JD_MODEL=claude-haiku-4-5
QA_MODEL=claude-sonnet-4-6
COVER_LETTER_MODEL=claude-opus-4-8
CLASSIFIER_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=voyage-3.5-lite

# Infra. Default is a zero-infra local SQLite file — no setup needed. Point
# this at a postgresql:// URL to opt into Postgres/pgvector (install a
# Postgres driver alongside SQLAlchemy first).
DATABASE_URL=sqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0

# CORS allowed origins as a REGEX (not a literal). Must match the dynamic
# extension origin chrome-extension://<id>. Default covers the extension + localhost.
CORS_ORIGIN_REGEX=chrome-extension://.*|http://localhost(:\d+)?|http://127\.0\.0\.1(:\d+)?
ENV=dev
